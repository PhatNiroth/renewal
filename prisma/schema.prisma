generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────
// Lightweight mirror of dashboard.krawma.com users.
// Auth is handled entirely by the dashboard — no password or session stored here.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responsibleFor      Subscription[]       @relation("ResponsibleUser")
  renewalLogs         RenewalLog[]         @relation("RenewalLogs")
  notificationTargets NotificationConfig[] @relation("NotifyUsers")
}

// ─── Vendor Categories ────────────────────────────────────────────────────────

model VendorCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("gray")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendors Vendor[]
}

// ─── Vendors ──────────────────────────────────────────────────────────────────

model Vendor {
  id           String  @id @default(cuid())
  name         String  @unique
  slug         String  @unique
  categoryId   String?
  website      String?
  contactEmail String?
  contactName  String?
  contactPhone String?
  notes         String?
  paymentMethod String?
  isActive      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category      VendorCategory? @relation(fields: [categoryId], references: [id])
  subscriptions Subscription[]
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id            String             @id @default(cuid())
  vendorId      String
  planName      String
  kind          SubscriptionKind   @default(SUBSCRIPTION)
  department    Department?
  cost          Int                // in cents
  currency      String             @default("usd")
  billingCycle  BillingCycle       @default(MONTHLY)
  customDays    Int?               // only used when billingCycle = CUSTOM
  startDate     DateTime
  renewalDate   DateTime
  status        SubscriptionStatus @default(ACTIVE)
  autoRenew     Boolean            @default(false)
  // Card fields — only used when kind = CARD. Last 4 ONLY, never full PAN.
  cardBrand     String?
  cardLast4     String?
  responsibleId   String?
  notes           String?
  documentPath    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  vendor              Vendor               @relation(fields: [vendorId], references: [id])
  responsible         User?                @relation("ResponsibleUser", fields: [responsibleId], references: [id])
  renewalLogs         RenewalLog[]
  notificationConfigs NotificationConfig[]
  notificationLogs    NotificationLog[]

  @@index([renewalDate])
  @@index([status])
  @@index([responsibleId])
  @@index([vendorId])
}

// ─── Renewal Logs ────────────────────────────────────────────────────────────

model RenewalLog {
  id               String       @id @default(cuid())
  subscriptionId   String
  previousDate     DateTime
  newDate          DateTime
  renewedById      String
  notes            String?
  createdAt        DateTime     @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  renewedBy    User         @relation("RenewalLogs", fields: [renewedById], references: [id])

  @@index([subscriptionId])
  @@index([renewedById])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationConfig {
  id             String       @id @default(cuid())
  subscriptionId String
  daysBefore     Int
  channel        NotifChannel @default(EMAIL)
  createdAt      DateTime     @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  notifyUsers  User[]       @relation("NotifyUsers")
}

model NotificationLog {
  id             String    @id @default(cuid())
  subscriptionId String
  type           NotifType
  scheduledFor   DateTime
  sentAt         DateTime?
  recipients     Json
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, type, scheduledFor])
  @@index([subscriptionId])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Department {
  IT
  FINANCE
  OPERATIONS
  HR
  MARKETING
  SALES
  LEGAL
  MANAGEMENT
  SUPPORT
  PROCUREMENT
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMESTER
  YEARLY
  ONE_TIME
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}

enum SubscriptionKind {
  SUBSCRIPTION
  MEMBERSHIP
  CARD
  CONTRACT
  LEASE
  LICENSE
  INSURANCE
  DOMAIN
  PERMIT
  OTHER
}

enum NotifChannel {
  EMAIL
  TELEGRAM
}

model GlobalNotificationSetting {
  id             String  @id @default("global")
  renewal7d      Boolean @default(true)
  renewal3d      Boolean @default(true)
  renewal1d      Boolean @default(true)
  renewalExpired Boolean @default(true)
}

enum NotifType {
  RENEWAL_REMINDER_90_DAYS
  RENEWAL_REMINDER_30_DAYS
  RENEWAL_REMINDER_14_DAYS
  RENEWAL_REMINDER_7_DAYS
  RENEWAL_REMINDER_3_DAYS
  RENEWAL_REMINDER_1_DAY
  RENEWAL_SUCCESS
  RENEWAL_FAILED
  RENEWAL_EXPIRED
}
