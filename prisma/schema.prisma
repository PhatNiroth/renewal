generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  isAdmin   Boolean  @default(false)
  roleId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role                Role?                @relation(fields: [roleId], references: [id])
  responsibleFor      Subscription[]       @relation("ResponsibleUser")
  payments            Payment[]
  renewalLogs         RenewalLog[]         @relation("RenewalLogs")
  notificationTargets NotificationConfig[] @relation("NotifyUsers")
  sessions            Session[]
  notificationPref    NotificationPref?
}

model NotificationPref {
  id              String  @id @default(cuid())
  userId          String  @unique
  renewal7d       Boolean @default(true)
  renewal3d       Boolean @default(true)
  renewal1d       Boolean @default(true)
  renewalExpired  Boolean @default(false)
  telegramChatId  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Roles & Permissions ──────────────────────────────────────────────────────

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  isSystem  Boolean  @default(false) // system roles cannot be deleted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions Permission[]
  users       User[]
}

model Permission {
  id        String @id @default(cuid())
  roleId    String
  module    Module
  canView   Boolean @default(false)
  canAdd    Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
}

// ─── Vendor Categories ────────────────────────────────────────────────────────

model VendorCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("gray")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendors Vendor[]
}

// ─── Vendors ──────────────────────────────────────────────────────────────────

model Vendor {
  id           String  @id @default(cuid())
  name         String  @unique
  slug         String  @unique
  categoryId   String?
  website      String?
  contactEmail String?
  contactName  String?
  contactPhone String?
  notes         String?
  paymentMethod String?
  isActive      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category      VendorCategory? @relation(fields: [categoryId], references: [id])
  subscriptions Subscription[]
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model Subscription {
  id            String             @id @default(cuid())
  vendorId      String
  planName      String
  department    Department?
  cost          Int                // in cents
  currency      String             @default("usd")
  billingCycle  BillingCycle       @default(MONTHLY)
  customDays    Int?               // only used when billingCycle = CUSTOM
  startDate     DateTime
  renewalDate   DateTime
  status        SubscriptionStatus @default(ACTIVE)
  autoRenew     Boolean            @default(false)
  responsibleId   String?
  paymentMethodId String?
  notes           String?
  documentPath    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  vendor              Vendor               @relation(fields: [vendorId], references: [id])
  responsible         User?                @relation("ResponsibleUser", fields: [responsibleId], references: [id])
  paymentMethod       PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  payments            Payment[]
  renewalLogs         RenewalLog[]
  notificationConfigs NotificationConfig[]
  notificationLogs    NotificationLog[]

  @@index([renewalDate])
  @@index([status])
  @@index([responsibleId])
  @@index([vendorId])
  @@index([paymentMethodId])
}

// ─── Payment Methods ──────────────────────────────────────────────────────────

model PaymentMethod {
  id           String            @id @default(cuid())
  name         String            // "Marketing Visa", "Ops Bank Account"
  type         PaymentMethodType
  // Card fields — last 4 ONLY, never full PAN; never CVV.
  cardBrand    String?           // VISA, MASTERCARD, AMEX, ...
  cardLast4    String?           // exactly 4 digits
  cardExpiry   String?           // "MM/YY" — display only
  // Bank fields
  bankName     String?
  accountLast4 String?
  // Catch-all for INVOICE / WIRE / CHECK / OTHER
  reference    String?           // PO-2024-0123, IBAN ref, check #, etc.
  notes        String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
}

// ─── Renewal Logs ────────────────────────────────────────────────────────────

model RenewalLog {
  id               String       @id @default(cuid())
  subscriptionId   String
  previousDate     DateTime
  newDate          DateTime
  renewedById      String
  notes            String?
  createdAt        DateTime     @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  renewedBy    User         @relation("RenewalLogs", fields: [renewedById], references: [id])

  @@index([subscriptionId])
  @@index([renewedById])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Int      // in cents
  currency       String   @default("usd")
  paidAt         DateTime
  paidById       String?
  note           String?
  receiptUrl     String?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  paidBy       User?        @relation(fields: [paidById], references: [id])

  @@index([subscriptionId])
  @@index([paidById])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationConfig {
  id             String       @id @default(cuid())
  subscriptionId String
  daysBefore     Int
  channel        NotifChannel @default(EMAIL)
  createdAt      DateTime     @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  notifyUsers  User[]       @relation("NotifyUsers")
}

model NotificationLog {
  id             String    @id @default(cuid())
  subscriptionId String
  type           NotifType
  scheduledFor   DateTime
  sentAt         DateTime?
  recipients     Json
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, type, scheduledFor])
  @@index([subscriptionId])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Module {
  SUBSCRIPTIONS
  RENEWALS
  VENDORS
  VENDOR_CATEGORIES
  PAYMENTS
}

enum Department {
  IT
  FINANCE
  OPERATIONS
  HR
  MARKETING
  SALES
  LEGAL
  MANAGEMENT
  SUPPORT
  PROCUREMENT
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMESTER
  YEARLY
  ONE_TIME
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
}

enum NotifChannel {
  EMAIL
  TELEGRAM
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER
  INVOICE
  WIRE
  CHECK
  PAYPAL
  CASH
  OTHER
}

enum NotifType {
  RENEWAL_REMINDER_90_DAYS
  RENEWAL_REMINDER_30_DAYS
  RENEWAL_REMINDER_14_DAYS
  RENEWAL_REMINDER_7_DAYS
  RENEWAL_REMINDER_3_DAYS
  RENEWAL_REMINDER_1_DAY
  RENEWAL_SUCCESS
  RENEWAL_FAILED
}
