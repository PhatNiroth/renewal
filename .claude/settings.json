{
  "permissions": {
    "allow": [
      "Bash(find . *)",
      "Bash(find /BTNG *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(npm run *)",
      "Bash(npm install)",
      "Bash(npx prisma *)",
      "Bash(npx tsx *)",
      "Bash(npx tsc *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git worktree *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)",
      "Bash(drop *)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /BTNG/Krawma-Renewal && npx tsc --noEmit 2>&1 | head -20 || true",
            "statusMessage": "Checking types..."
          }
        ]
      }
    ]
  }
}
